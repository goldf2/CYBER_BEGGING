WXPAY_APP_ID=微信公众号APPID
WXPAY_MCH_ID=微信商户号
WXPAY_PRIVATE_KEY=商户私钥（PEM格式）
WXPAY_SERIAL_NO=证书序列号
WXPAY_API_V3_KEY=API v3密钥
WXPAY_NOTIFY_URL=https://your-domain.com/api/payment/notify

CREEM_API_KEY=creem_test_xxx
CREEM_PRODUCT_1USD=产品ID_1美元
CREEM_PRODUCT_2USD=产品ID_2美元
CREEM_PRODUCT_5USD=产品ID_5美元
CREEM_PRODUCT_10USD=产品ID_10美元
CREEM_WEBHOOK_SECRET=webhook密钥
CREEM_TEST_MODE=true

# Supabase 配置
# 从 https://supabase.com 创建项目后获取
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# Anon Key（用于前端公开访问，可安全暴露）
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
# Service Role Key（用于服务端绕过 RLS，请勿泄露）
SUPABASE_SERVICE_ROLE_KEY=xxx

PORT=3000
DOMAIN=your-domain.com